generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Subject {
  id                 String             @id @default(uuid()) @map("id")
  subjectCode        String             @unique @map("subject_code")
  subjectName        String             @map("subject_name")
  department         String
  semester           Int
  credits            Int?
  isDeleted          Boolean            @default(false) @map("is_deleted")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  assignments        Assignment[]
  attendance         Attendance[]
  chapters           Chapter[]
  homeworks          Homework[]
  materialCategories MaterialCategory[]
  qrSessions         QRSession[]
  studyMaterials     StudyMaterial[]
  timetables         Timetable[]        @relation("TimetableSubject")

  @@map("subjects")
}

model Batch {
  id                 String             @id @default(uuid()) @map("id")
  batchName          String             @map("batch_name")
  batchCode          String?            @unique @map("batch_code")
  department         String
  course             String
  courseId           String?            @map("course_id")
  semester           Int
  academicYear       String             @map("academic_year")
  capacity           Int?
  currentStrength    Int?               @default(0) @map("current_strength")
  batchTiming        String?            @map("batch_timing")
  classroom          String?
  mode               String?            @default("offline")
  facultyId          String?            @map("faculty_id")
  startDate          DateTime?          @map("start_date")
  endDate            DateTime?          @map("end_date")
  status             String?            @default("active")
  isDeleted          Boolean            @default(false) @map("is_deleted")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  assignments        Assignment[]
  attendance         Attendance[]
  homeworks          Homework[]
  materialCategories MaterialCategory[]
  qrSessions         QRSession[]
  students           Student[]
  studyMaterials     StudyMaterial[]
  timetables         Timetable[]        @relation("TimetableBatch")
  batchStudents      BatchStudent[]
  transferHistoryOld BatchTransfer[]    @relation("OldBatchTransfer")
  transferHistoryNew BatchTransfer[]    @relation("NewBatchTransfer")

  @@index([facultyId])
  @@index([status])
  @@map("batches")
}

model BatchStudent {
  id          String   @id @default(uuid()) @map("id")
  batchId     String   @map("batch_id")
  studentId   String   @map("student_id")
  allocatedAt DateTime @default(now()) @map("allocated_at")
  batch       Batch    @relation(fields: [batchId], references: [id])

  @@unique([batchId, studentId])
  @@index([batchId])
  @@index([studentId])
  @@map("batch_students")
}

model BatchTransfer {
  id          String   @id @default(uuid()) @map("id")
  studentId   String   @map("student_id")
  oldBatchId  String   @map("old_batch_id")
  newBatchId  String   @map("new_batch_id")
  transferDate DateTime @default(now()) @map("transfer_date")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")
  oldBatch    Batch    @relation("OldBatchTransfer", fields: [oldBatchId], references: [id])
  newBatch    Batch    @relation("NewBatchTransfer", fields: [newBatchId], references: [id])

  @@index([studentId])
  @@index([oldBatchId])
  @@index([newBatchId])
  @@map("batch_transfers")
}

model Classroom {
  id            String       @id @default(uuid()) @map("id")
  classroomCode String       @unique @map("classroom_code")
  building      String
  floor         Int
  roomNumber    String       @map("room_number")
  capacity      Int?
  isDeleted     Boolean      @default(false) @map("is_deleted")
  deletedAt     DateTime?    @map("deleted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  attendance    Attendance[]
  qrSessions    QRSession[]
  timetables    Timetable[]  @relation("TimetableClassroom")

  @@map("classrooms")
}

model Faculty {
  id                      String                  @id @default(uuid()) @map("id")
  facultyId               String                  @unique @map("faculty_id")
  firstName               String                  @map("first_name")
  lastName                String                  @map("last_name")
  fullName                String                  @map("full_name")
  gender                  String
  dateOfBirth             DateTime                @map("date_of_birth")
  email                   String                  @unique
  phone                   String                  @unique
  alternatePhone          String?                 @map("alternate_phone")
  profileImage            String?                 @map("profile_image")
  employeeId              String                  @unique @map("employee_id")
  designation             String
  department              String
  specialization          String[]
  qualification           String[]
  experience              Float
  joiningDate             DateTime                @map("joining_date")
  employmentType          String                  @map("employment_type")
  salary                  Decimal?                @map("salary")
  branch                  String
  campus                  String
  address                 Json                    @map("address")
  emergencyContact        Json                    @map("emergency_contact")
  username                String                  @unique
  password                String
  role                    String                  @default("faculty")
  permissions             String[]
  status                  String                  @default("active")
  assignedCourses         Json                    @default("[]") @map("assigned_courses")
  assignedSubjects        Json                    @default("[]") @map("assigned_subjects")
  assignedBatches         Json                    @default("[]") @map("assigned_batches")
  assignedSemesters       Json                    @default("[]") @map("assigned_semesters")
  transferHistory         Json                    @default("[]") @map("transfer_history")
  isDeleted               Boolean                 @default(false) @map("is_deleted")
  deletedAt               DateTime?               @map("deleted_at")
  createdById             String?                 @map("created_by_id")
  updatedById             String?                 @map("updated_by_id")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  assignmentLogs          AssignmentLog[]         @relation("AssignmentFaculty")
  assignmentLogsPerformed AssignmentLog[]         @relation("AssignmentPerformedBy")
  remindersCreated        AssignmentReminder[]    @relation("ReminderCreatedBy")
  submissionsGraded       AssignmentSubmission[]  @relation("SubmissionGradedBy")
  assignmentCreatedBy     Assignment[]            @relation("AssignmentCreatedBy")
  facultyAssignments      Assignment[]            @relation("FacultyAssignment")
  assignmentUpdatedBy     Assignment[]            @relation("AssignmentUpdatedBy")
  correctionsApproved     AttendanceCorrection[]  @relation("CorrectionApprovedBy")
  correctionsCreated      AttendanceCorrection[]  @relation("CorrectionCreatedBy")
  attendanceCreatedBy     Attendance[]            @relation("AttendanceCreatedBy")
  attendanceMarkedBy      Attendance[]            @relation("AttendanceMarkedBy")
  attendanceUpdatedBy     Attendance[]            @relation("AttendanceUpdatedBy")
  evaluationCreatedBy     Evaluation[]            @relation("EvaluationCreatedBy")
  evaluations             Evaluation[]            @relation("EvaluationFaculty")
  evaluationUpdatedBy     Evaluation[]            @relation("EvaluationUpdatedBy")
  faceRecognitions        FaceRecognition[]       @relation("FaceRecognitionCreatedBy")
  createdBy               Faculty?                @relation("FacultyCreatedBy", fields: [createdById], references: [id])
  createdFaculty          Faculty[]               @relation("FacultyCreatedBy")
  updatedBy               Faculty?                @relation("FacultyUpdatedBy", fields: [updatedById], references: [id])
  updatedFaculty          Faculty[]               @relation("FacultyUpdatedBy")
  facultyTransfers        FacultyTransfer[]       @relation("FacultyTransferFaculty")
  transfersPerformed      FacultyTransfer[]       @relation("FacultyTransferPerformedBy")
  fingerprintsCreated     FingerprintAttendance[] @relation("FingerprintCreatedBy")
  holidaysCreated         Holiday[]               @relation("HolidayCreatedBy")
  holidaysUpdated         Holiday[]               @relation("HolidayUpdatedBy")
  homeworkCreatedBy       Homework[]              @relation("HomeworkCreatedBy")
  homeworks               Homework[]
  homeworkUpdatedBy       Homework[]              @relation("HomeworkUpdatedBy")
  categoriesCreated       MaterialCategory[]      @relation("CategoryCreatedBy")
  categoriesUpdated       MaterialCategory[]      @relation("CategoryUpdatedBy")
  qrSessionsCreated       QRSession[]             @relation("QRSessionCreatedBy")
  qrSessions              QRSession[]             @relation("QRSessionFaculty")
  studentsCreated         Student[]               @relation("StudentCreatedBy")
  studentsUpdated         Student[]               @relation("StudentUpdatedBy")
  studyMaterialsCreated   StudyMaterial[]         @relation("StudyMaterialCreatedBy")
  studyMaterialsUpdated   StudyMaterial[]         @relation("StudyMaterialUpdatedBy")
  studyMaterialsUploaded  StudyMaterial[]         @relation("StudyMaterialUploadedBy")
  timetableCreatedBy      Timetable[]             @relation("TimetableCreatedBy")
  timetables              Timetable[]
  timetableUpdatedBy      Timetable[]             @relation("TimetableUpdatedBy")

  @@index([createdById])
  @@index([updatedById])
  @@index([department])
  @@index([status])
  @@map("faculty")
}

model Student {
  id                     String                  @id @default(uuid()) @map("id")
  studentId              String                  @unique @map("student_id")
  firstName              String                  @map("first_name")
  lastName               String                  @map("last_name")
  fullName               String                  @map("full_name")
  email                  String                  @unique
  phone                  String
  rollNumber             String                  @map("roll_number")
  department             String
  course                 String
  semester               Int
  batch                  String
  batchId                String?                 @map("batch_id")
  section                String?
  gender                 String
  dateOfBirth            DateTime                @map("date_of_birth")
  address                Json?
  profileImage           String?                 @map("profile_image")
  status                 String                  @default("active")
  isDeleted              Boolean                 @default(false) @map("is_deleted")
  deletedAt              DateTime?               @map("deleted_at")
  createdById            String?                 @map("created_by_id")
  updatedById            String?                 @map("updated_by_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  password               String?
  role                   String?                 @default("STUDENT")
  reminders              AssignmentReminder[]
  submissions            AssignmentSubmission[]
  corrections            AttendanceCorrection[]
  attendances            Attendance[]
  faceRecognitions       FaceRecognition[]
  fingerprintAttendances FingerprintAttendance[]
  qrScans                QRScan[]
  batchRef               Batch?                  @relation(fields: [batchId], references: [id])
  createdBy              Faculty?                @relation("StudentCreatedBy", fields: [createdById], references: [id])
  updatedBy              Faculty?                @relation("StudentUpdatedBy", fields: [updatedById], references: [id])
  parents                ParentStudent[]

  @@index([batchId])
  @@index([createdById])
  @@index([updatedById])
  @@index([department])
  @@index([status])
  @@map("students")
}

model Attendance {
  id                     String                  @id @default(uuid()) @map("id")
  attendanceCode         String                  @unique @map("attendance_code")
  studentId              String                  @map("student_id")
  facultyId              String                  @map("faculty_id")
  subjectId              String                  @map("subject_id")
  batchId                String                  @map("batch_id")
  classroomId            String                  @map("classroom_id")
  attendanceDate         DateTime                @map("attendance_date")
  startTime              DateTime                @map("start_time")
  endTime                DateTime                @map("end_time")
  attendanceMethod       AttendanceMethod        @map("attendance_method")
  attendanceStatus       AttendanceStatus        @map("attendance_status")
  remarks                String?
  createdById            String                  @map("created_by_id")
  updatedById            String                  @map("updated_by_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  isDeleted              Boolean                 @default(false) @map("is_deleted")
  deletedAt              DateTime?               @map("deleted_at")
  corrections            AttendanceCorrection[]
  batch                  Batch                   @relation(fields: [batchId], references: [id])
  classroom              Classroom               @relation(fields: [classroomId], references: [id])
  createdBy              Faculty                 @relation("AttendanceCreatedBy", fields: [createdById], references: [id])
  faculty                Faculty                 @relation("AttendanceMarkedBy", fields: [facultyId], references: [id])
  student                Student                 @relation(fields: [studentId], references: [id])
  subject                Subject                 @relation(fields: [subjectId], references: [id])
  updatedBy              Faculty                 @relation("AttendanceUpdatedBy", fields: [updatedById], references: [id])
  faceRecognitions       FaceRecognition[]
  fingerprintAttendances FingerprintAttendance[]
  qrScans                QRScan[]

  @@index([studentId])
  @@index([facultyId])
  @@index([subjectId])
  @@index([batchId])
  @@index([classroomId])
  @@index([attendanceDate])
  @@index([facultyId, attendanceDate])
  @@map("attendances")
}

model Timetable {
  id                String    @id @default(uuid()) @map("id")
  timetableId       String    @unique @map("timetable_id")
  academicYear      String    @map("academic_year")
  semester          Int
  department        String
  course            String
  batch             String
  section           String?
  subject           String
  subjectCode       String    @map("subject_code")
  subjectId         String?   @map("subject_id")
  facultyId         String    @map("faculty_id")
  facultyName       String    @map("faculty_name")
  classroomId       String    @map("classroom_id")
  batchId           String?   @map("batch_id")
  batchName         String    @map("batch_name")
  building          String
  floor             Int
  roomNumber        String    @map("room_number")
  dayOfWeek         String    @map("day_of_week")
  startTime         DateTime  @map("start_time")
  endTime           DateTime  @map("end_time")
  duration          String
  status            String    @default("scheduled")
  remarks           String?
  recurringClass    Boolean   @default(false) @map("recurring_class")
  recurrenceType    String?   @map("recurrence_type")
  recurrenceEndDate DateTime? @map("recurrence_end_date")
  createdBy         String    @map("created_by")
  updatedBy         String    @map("updated_by")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  batchRef          Batch?    @relation("TimetableBatch", fields: [batchId], references: [id])
  classroom         Classroom @relation("TimetableClassroom", fields: [classroomId], references: [id])
  createdByFaculty  Faculty   @relation("TimetableCreatedBy", fields: [createdBy], references: [id])
  faculty           Faculty   @relation(fields: [facultyId], references: [id])
  subjectRef        Subject?  @relation("TimetableSubject", fields: [subjectId], references: [id])
  updatedByFaculty  Faculty   @relation("TimetableUpdatedBy", fields: [updatedBy], references: [id])

  @@index([facultyId])
  @@index([subjectId])
  @@index([batchId])
  @@index([classroomId])
  @@index([dayOfWeek])
  @@map("timetables")
}

model FacultyTransfer {
  id              String                   @id @default(uuid()) @map("id")
  facultyId       String                   @map("faculty_id")
  fromBranch      String                   @map("from_branch")
  fromDepartment  String                   @map("from_department")
  toBranch        String                   @map("to_branch")
  toDepartment    String                   @map("to_department")
  transferDate    DateTime                 @map("transfer_date")
  reason          String
  approvedBy      String?                  @map("approved_by")
  status          CorrectionApprovalStatus @default(pending)
  performedBy     String                   @map("performed_by")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  deletedAt       DateTime?                @map("deleted_at")
  isDeleted       Boolean                  @default(false) @map("is_deleted")
  faculty         Faculty                  @relation("FacultyTransferFaculty", fields: [facultyId], references: [id])
  performedByUser Faculty                  @relation("FacultyTransferPerformedBy", fields: [performedBy], references: [id])

  @@index([facultyId])
  @@index([performedBy])
  @@index([status])
  @@index([transferDate])
  @@map("faculty_transfers")
}

model AssignmentLog {
  id              String    @id @default(uuid()) @map("id")
  facultyId       String    @map("faculty_id")
  action          String
  entityType      String    @map("entity_type")
  entityId        String?   @map("entity_id")
  entityName      String?   @map("entity_name")
  oldValue        Json?     @map("old_value")
  newValue        Json?     @map("new_value")
  performedBy     String    @map("performed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  faculty         Faculty   @relation("AssignmentFaculty", fields: [facultyId], references: [id])
  performedByUser Faculty   @relation("AssignmentPerformedBy", fields: [performedBy], references: [id])

  @@index([facultyId])
  @@index([performedBy])
  @@map("assignment_logs")
}

model Holiday {
  id                    String    @id @default(uuid()) @map("id")
  holidayName           String    @map("holiday_name")
  holidayType           String    @map("holiday_type")
  startDate             DateTime  @map("start_date")
  endDate               DateTime  @map("end_date")
  description           String?
  applicableDepartments String[]  @map("applicable_departments")
  academicYear          String?   @map("academic_year")
  isDeleted             Boolean   @default(false) @map("is_deleted")
  deletedAt             DateTime? @map("deleted_at")
  createdBy             String    @map("created_by")
  updatedBy             String    @map("updated_by")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdByFaculty      Faculty   @relation("HolidayCreatedBy", fields: [createdBy], references: [id])
  updatedByFaculty      Faculty   @relation("HolidayUpdatedBy", fields: [updatedBy], references: [id])

  @@index([createdBy])
  @@index([updatedBy])
  @@index([startDate])
  @@index([endDate])
  @@index([holidayType])
  @@map("holidays")
}

model FaceRecognition {
  id              String            @id @default(uuid()) @map("id")
  sessionId       String            @map("session_id")
  studentId       String            @map("student_id")
  attendanceId    String?           @map("attendance_id")
  confidence      Float             @default(0)
  recognitionTime DateTime          @map("recognition_time")
  imageUrl        String?           @map("image_url")
  deviceId        String?           @map("device_id")
  metadata        Json              @default("{}")
  status          RecognitionStatus @default(pending)
  createdById     String            @map("created_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  isDeleted       Boolean           @default(false) @map("is_deleted")
  attendance      Attendance?       @relation(fields: [attendanceId], references: [id])
  createdBy       Faculty           @relation("FaceRecognitionCreatedBy", fields: [createdById], references: [id])
  student         Student           @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([attendanceId])
  @@index([createdById])
  @@index([sessionId])
  @@index([status])
  @@map("face_recognitions")
}

model FingerprintAttendance {
  id                 String            @id @default(uuid()) @map("id")
  sessionId          String            @map("session_id")
  fingerprintId      String            @map("fingerprint_id")
  studentId          String            @map("student_id")
  attendanceId       String?           @map("attendance_id")
  verificationStatus FingerprintStatus @default(pending) @map("verification_status")
  recognitionTime    DateTime          @map("recognition_time")
  scannerId          String?           @map("scanner_id")
  metadata           Json              @default("{}")
  createdById        String            @map("created_by_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  isDeleted          Boolean           @default(false) @map("is_deleted")
  attendance         Attendance?       @relation(fields: [attendanceId], references: [id])
  createdBy          Faculty           @relation("FingerprintCreatedBy", fields: [createdById], references: [id])
  student            Student           @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([attendanceId])
  @@index([createdById])
  @@index([sessionId])
  @@index([verificationStatus])
  @@map("fingerprint_attendances")
}

model QRSession {
  id             String    @id @default(uuid()) @map("id")
  qrToken        String    @unique @map("qr_token")
  facultyId      String    @map("faculty_id")
  subjectId      String    @map("subject_id")
  batchId        String    @map("batch_id")
  classroomId    String    @map("classroom_id")
  attendanceDate DateTime  @map("attendance_date")
  startTime      DateTime  @map("start_time")
  endTime        DateTime  @map("end_time")
  expiryTime     DateTime  @map("expiry_time")
  status         QRStatus  @default(active)
  createdById    String    @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  scans          QRScan[]
  batch          Batch     @relation(fields: [batchId], references: [id])
  classroom      Classroom @relation(fields: [classroomId], references: [id])
  createdBy      Faculty   @relation("QRSessionCreatedBy", fields: [createdById], references: [id])
  faculty        Faculty   @relation("QRSessionFaculty", fields: [facultyId], references: [id])
  subject        Subject   @relation(fields: [subjectId], references: [id])

  @@index([facultyId])
  @@index([subjectId])
  @@index([batchId])
  @@index([classroomId])
  @@index([createdById])
  @@index([status])
  @@map("qr_sessions")
}

model QRScan {
  id           String       @id @default(uuid()) @map("id")
  qrSessionId  String       @map("qr_session_id")
  studentId    String       @map("student_id")
  attendanceId String?      @map("attendance_id")
  scannedAt    DateTime     @map("scanned_at")
  status       QRScanStatus @default(pending)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  isDeleted    Boolean      @default(false) @map("is_deleted")
  attendance   Attendance?  @relation(fields: [attendanceId], references: [id])
  qrSession    QRSession    @relation(fields: [qrSessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id])

  @@index([qrSessionId])
  @@index([studentId])
  @@index([attendanceId])
  @@map("qr_scans")
}

model AttendanceCorrection {
  id              String                   @id @default(uuid()) @map("id")
  attendanceId    String                   @map("attendance_id")
  studentId       String                   @map("student_id")
  attendanceDate  DateTime                 @map("attendance_date")
  currentStatus   AttendanceStatus         @map("current_status")
  requestedStatus AttendanceStatus         @map("requested_status")
  reason          String
  attachmentUrl   String?                  @map("attachment_url")
  approvalStatus  CorrectionApprovalStatus @default(pending) @map("approval_status")
  approvedById    String?                  @map("approved_by_id")
  approvalDate    DateTime?                @map("approval_date")
  createdById     String                   @map("created_by_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  deletedAt       DateTime?                @map("deleted_at")
  isDeleted       Boolean                  @default(false) @map("is_deleted")
  approvedBy      Faculty?                 @relation("CorrectionApprovedBy", fields: [approvedById], references: [id])
  attendance      Attendance               @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  createdBy       Faculty                  @relation("CorrectionCreatedBy", fields: [createdById], references: [id])
  student         Student                  @relation(fields: [studentId], references: [id])

  @@index([attendanceId])
  @@index([studentId])
  @@index([approvedById])
  @@index([createdById])
  @@index([approvalStatus])
  @@map("attendance_corrections")
}

model Department {
  id                 String             @id @default(uuid()) @map("id")
  name               String             @unique
  code               String             @unique
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  isDeleted          Boolean            @default(false) @map("is_deleted")
  assignments        Assignment[]
  homeworks          Homework[]
  materialCategories MaterialCategory[]
  studyMaterials     StudyMaterial[]

  @@map("departments")
}

model Course {
  id                    String                 @id @default(uuid()) @map("id")
  name                  String                 @unique
  code                  String                 @unique
  description           String?
  duration              Int?
  durationUnit          String?                @default("months") @map("duration_unit")
  category              String?
  fee                   Decimal?               @default(0)
  maximumCapacity       Int?                   @map("maximum_capacity")
  enrolledCount         Int?                   @default(0) @map("enrolled_count")
  minAge                Int?                   @map("min_age")
