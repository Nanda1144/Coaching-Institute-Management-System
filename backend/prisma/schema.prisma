model Payment {
  id                    String    @id @default(uuid()) @map("id")
  studentId             String    @map("student_id")
  studentName           String    @map("student_name")
  amount                Decimal   @map("amount")
  paymentMethod         String?   @map("payment_method")
  transactionId         String?   @unique @map("transaction_id")
  description           String?
  status                String    @default("created")
  refundedAmount        Decimal?  @default(0) @map("refunded_amount")
  refundReason          String?   @map("refund_reason")
  refundedAt            DateTime? @map("refunded_at")
  refundedBy            String?   @map("refunded_by")
  // Gateway-specific fields
  gateway               String?   @map("gateway")
  gatewayOrderId        String?   @map("gateway_order_id")
  gatewayPaymentId      String?   @map("gateway_payment_id")
  gatewaySignature      String?   @map("gateway_signature")
  providerReferenceId   String?   @map("provider_reference_id")
  merchantOrderId       String?   @map("merchant_order_id")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  stripeClientSecret    String?   @map("stripe_client_secret")
  currency              String?   @default("INR")
  receiptUrl            String?   @map("receipt_url")
  verifiedAt            DateTime? @map("verified_at")
  verifiedBy            String?   @map("verified_by")
  verificationMode      String?   @map("verification_mode")
  notes                 Json?     @default("{}")
  rawResponse           Json?     @default("{}")
  isDeleted             Boolean   @default(false) @map("is_deleted")
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([status])
  @@index([transactionId])
  @@index([gateway])
  @@index([gatewayOrderId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

