NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true&connection_limit=5&pool_timeout=10
DIRECT_URL=postgresql://user:password@host:5432/database
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=https://your-frontend-domain.com
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
COOKIE_SECRET=change-this-to-a-random-cookie-secret
DB_SSL_REJECT_UNAUTHORIZED=true
SKIP_AUTH=false

# Cloud Storage (optional)
# CLOUD_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=ciiims-documents

# Payment Gateways (optional)
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret
# PHONEPE_MERCHANT_ID=your_merchant_id
# PHONEPE_SALT_KEY=your_salt_key
# PHONEPE_SALT_INDEX=1
# PHONEPE_BASE_URL=https://api.phonepe.com/apis/hermes
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=your_webhook_secret
